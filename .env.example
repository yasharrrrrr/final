# ---------------------------------------------------------------------------
# BAORCO Online Shop - environment configuration
# Copy this file to ".env" and fill in real values.
# ---------------------------------------------------------------------------

# Core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*
# Comma separated origins allowed to call the API (Android app / web admin)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:8000

# ---------------------------------------------------------------------------
# Database
#   DB_ENGINE=sqlite  -> uses local db.sqlite3 (great for development)
#   DB_ENGINE=mssql   -> uses Microsoft SQL Server via mssql-django
# ---------------------------------------------------------------------------
DB_ENGINE=sqlite

DB_NAME=baorco
DB_USER=sa
DB_PASSWORD=YourStrong!Passw0rd
DB_HOST=localhost
DB_PORT=1433
DB_DRIVER=ODBC Driver 17 for SQL Server

# ---------------------------------------------------------------------------
# SMS.ir (https://sms.ir) - verify/template based sending
# ---------------------------------------------------------------------------
SMSIR_API_KEY=2qAmtPjmMp7YZ6tkLNzW1nZ4AAj5nRpaA7mZacUbD85xAB4G
SMSIR_SANDBOX_API_KEY=jX4ig30x5bXrcu75SjrdVLJoEj2op3daJLyEyf1b6dIOiAIe
SMSIR_USE_SANDBOX=True
SMSIR_VERIFY_URL=https://api.sms.ir/v1/send/verify

# Template ids supplied by SMS.ir panel
SMSIR_OTP_TEMPLATE_ID=769673
SMSIR_ORDER_TEMPLATE_ID=800879

# OTP behaviour
OTP_LENGTH=5
OTP_TTL_SECONDS=120

# JWT lifetimes (minutes / days)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
